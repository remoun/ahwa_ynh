#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Verified against YNH 12.1.39 via package_check (LXC bookworm/stable).

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

ynh_print_info "Declaring files to be backed up..."

# Source: not backed up — re-cloned on restore from the pinned commit.
# Bun: not backed up — reinstalled on restore.
# What matters is the SQLite file and any operator config.

ynh_backup "$data_dir"
ynh_backup "/etc/systemd/system/$app.service"
ynh_backup "/etc/nginx/conf.d/$domain.d/$app.conf"

# .env (operator-supplied LLM keys) only exists if the admin created it.
[ -f "$install_dir/.env" ] && ynh_backup "$install_dir/.env"
