#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Verified against YNH 12.1.39 via package_check (LXC bookworm/stable).

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

ynh_script_progression "Restoring Ahwa..."

# Re-fetch source from the pinned tarball + reinstall Bun + rebuild.
# Same as install, minus the data_dir provisioning (data_dir is restored
# from backup below).
ynh_setup_source --dest_dir="$install_dir"
chown -R "$app:$app" "$install_dir"

install_bun "$install_dir"
chown -R "$app:$app" "$install_dir/.bun"

# build/ is in the prebuilt tarball; only install runtime deps.
bun_app "$install_dir" install --production --frozen-lockfile

ynh_script_progression "Restoring data..."
ynh_restore "$data_dir"
chown -R "$app:$app" "$data_dir"

ynh_script_progression "Restoring systemd + nginx config..."
ynh_restore "/etc/systemd/system/$app.service"
ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"

# Restore the operator's .env if backed up; otherwise re-render from
# settings (handles backups taken before .env support landed).
ynh_restore "$install_dir/.env" || true
if [ ! -f "$install_dir/.env" ]; then
    llm_provider="$(ynh_app_setting_get --key=llm_provider)"
    llm_api_key="$(ynh_app_setting_get --key=llm_api_key)"
    ollama_url="$(ynh_app_setting_get --key=ollama_url)"
    share_secret="$(ynh_app_setting_get --key=share_secret)"
    [ -n "$llm_provider" ] && [ -n "$share_secret" ] && \
        render_env_file "$install_dir" "$llm_provider" "$llm_api_key" "$ollama_url" "$share_secret"
fi
if [ -f "$install_dir/.env" ]; then
    chmod 600 "$install_dir/.env"
    chown "$app:$app" "$install_dir/.env"
fi

systemctl daemon-reload
ynh_systemctl --service="$app" --action="start" --log_path="systemd"

ynh_script_progression "Restore complete."
