#!/bin/bash
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Verified against YNH 12.1.39 via package_check (LXC bookworm/stable).

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression "Stopping Ahwa..."
ynh_systemctl --service="$app" --action="stop" --log_path="systemd"

ynh_script_progression "Fetching upstream tarball..."
# Re-extract on top of the existing tree. .bun/, .env, node_modules,
# and other runtime files are preserved (they're not in the tarball);
# upstream files are replaced. The tarball URL + sha256 are pinned in
# manifest.toml's [resources.sources.main].
ynh_setup_source --dest_dir="$install_dir"
chown -R "$app:$app" "$install_dir"

ynh_script_progression "Installing production dependencies..."
# build/ is in the new tarball; only refresh runtime deps.
bun_app "$install_dir" install --production --frozen-lockfile

ynh_script_progression "Re-rendering systemd + nginx (in case templates changed)..."
ynh_config_add_systemd
ynh_config_add_nginx

# Re-render .env from settings — upgrades from before the config panel
# might have a stale or hand-edited file. Idempotent.
llm_provider="$(ynh_app_setting_get --key=llm_provider)"
llm_api_key="$(ynh_app_setting_get --key=llm_api_key)"
ollama_url="$(ynh_app_setting_get --key=ollama_url)"
share_secret="$(ynh_app_setting_get --key=share_secret)"
if [ -n "$llm_provider" ] && [ -n "$share_secret" ]; then
    render_env_file "$install_dir" "$llm_provider" "$llm_api_key" "$ollama_url" "$share_secret"
fi

ynh_script_progression "Starting Ahwa..."
ynh_systemctl --service="$app" --action="start" --log_path="systemd"

ynh_script_progression "Upgrade complete."
